<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
  <title>Atlas</title>
  <options customize="always" require-scripts="true" rootVolumeOnly="true" hostArchitectures="arm64"/>
  <choices-outline>
    <line choice="choice.docs"/>
    <line choice="choice.au"/>
    <line choice="choice.vst3"/>
  </choices-outline>

  <choice id="choice.docs" title="Accessible layout guide and Atlas folders" visible="false" selected="true" enabled="false">
    <pkg-ref id="plugins.alessio.atlas.docs"/>
  </choice>
  <choice id="choice.au" title="Audio Unit (AU)" description="Install Atlas.component for AU hosts." selected="true">
    <pkg-ref id="plugins.alessio.atlas.au"/>
  </choice>
  <choice id="choice.vst3" title="VST3" description="Install Atlas.vst3 for VST3 hosts." selected="true">
    <pkg-ref id="plugins.alessio.atlas.vst3"/>
  </choice>

  <pkg-ref id="plugins.alessio.atlas.docs" version="@VERSION@" onConclusion="none">Atlas-Docs.pkg</pkg-ref>
  <pkg-ref id="plugins.alessio.atlas.au" version="@VERSION@" onConclusion="none">Atlas-AU.pkg</pkg-ref>
  <pkg-ref id="plugins.alessio.atlas.vst3" version="@VERSION@" onConclusion="none">Atlas-VST3.pkg</pkg-ref>
</installer-gui-script>
